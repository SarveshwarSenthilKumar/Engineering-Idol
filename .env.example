# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this
DATABASE_PATH=events.db

# Alert Thresholds
CRITICAL_THRESHOLD=80
HIGH_THRESHOLD=60
ELEVATED_THRESHOLD=40
AQI_ALERT_THRESHOLD=150
SOUND_ALERT_THRESHOLD=80

# System Configuration
LOG_INTERVAL=60
REFRESH_RATE=5
RETENTION_DAYS=30

# Email Alerts (Gmail SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=alerts@example.com

# Gmail Configuration (for rasppi.py)
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_SENDER_PASSWORD=your-app-password
GMAIL_RECIPIENT_EMAIL=front-office@school.edu

# Microsoft Teams Configuration
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb3/...

# Notification Thresholds
ALARM_NOTIFICATION_THRESHOLD=80
MISBEHAVIOR_NOTIFICATION_THRESHOLD=60
MISBEHAVIOR_EXIT_THRESHOLD=40
NOTIFICATION_COOLDOWN=300

# SMS/Text Message Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
RECIPIENT_PHONE_NUMBER=+1234567890

# Sensor Configuration
SPIKE_THRESHOLD_DB=15
LOUD_THRESHOLD_DB=65
VOC_CLEAN_THRESHOLD=50
VOC_ACTIVITY_THRESHOLD=80
VOC_CHEMICAL_THRESHOLD=120
VOC_SMOKING_THRESHOLD=150
VOC_VAPING_THRESHOLD=180
PM_CLEAN_THRESHOLD=10
PM_SMOKE_THRESHOLD=40
PM_VAPING_THRESHOLD=60

# Radar Configuration
RADAR_TYPE=auto
RADAR_PORT=/dev/ttyUSB0

# Breathing Detection
BREATHING_FREQ_RANGE_MIN=0.15
BREATHING_FREQ_RANGE_MAX=0.4

# Threat Scoring Configuration
BASE_ESCALATION_FACTOR=1.5
TIME_DECAY_HALF_LIFE=300
PERSISTENCE_THRESHOLD=3
PERSISTENCE_MULTIPLIER=2.0

# Gas Sensor Parameters
RLOAD=10000
R0=20000
MQ135_CLEAN_AIR_RATIO=3.6

# Audio Configuration
SAMPLE_RATE=44100
WINDOW_TIME=1
REFERENCE_VOLTAGE=0.05

# Google Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash